@model IEnumerable<ProjetoAgendamento.Models.Agendamento>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .status-select {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 0.4rem center;
        background-size: 0.8em;
    }

    .opt-pendente { color: #eab308 !important; background-color: #1a1a1a !important; }
    .opt-atendido { color: #22c55e !important; background-color: #1a1a1a !important; }
    .opt-cancelado { color: #ef4444 !important; background-color: #1a1a1a !important; }

    .status-pendente { border-color: rgba(234, 179, 8, 0.4); color: #eab308; }
    .status-atendido { border-color: rgba(34, 197, 94, 0.4); color: #22c55e; }
    .status-cancelado { border-color: rgba(239, 68, 68, 0.4); color: #ef4444; }
</style>

<div class="card-moderno p-4 md:p-8 animate-in fade-in duration-500 overflow-hidden">
    <div class="flex flex-col sm:flex-row justify-between items-center mb-10 gap-4">
        <h2 class="text-xl md:text-2xl font-black font-mono uppercase italic tracking-tighter" style="color: var(--text-main)">
            PAINEL DE AGENDAMENTOS
        </h2>
        
        <button onclick="abrirModal()" class="px-5 py-2 text-[10px] font-bold rounded-full transition-all active:scale-95 shadow-md uppercase tracking-wider" 
                style="background: var(--accent); color: #000;">
            Novo Agendamento
        </button>
    </div>

    <div class="overflow-x-auto no-scrollbar">
        <table class="w-full text-left border-separate border-spacing-y-3 min-w-[700px]">
            <thead>
                <tr class="text-[9px] uppercase tracking-[0.2em] opacity-30 font-black">
                    <th class="px-6 pb-2">Cliente</th>
                    <th class="px-6 pb-2">Serviço</th>
                    <th class="px-6 pb-2 text-center">Data / Hora</th>
                    <th class="px-6 pb-2 text-center">Status</th>
                    <th class="px-6 pb-2 text-right w-10">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null) {
                    @foreach (var item in Model) {
                        var statusClass = item.Status == "Atendido" ? "status-atendido" : 
                                         item.Status == "Cancelado" ? "status-cancelado" : "status-pendente";
                        
                        <tr class="group hover:bg-white/[0.03] transition-all">
                            <td class="px-6 py-5 bg-black/20 rounded-l-2xl font-bold text-sm">@item.NomeCliente</td>
                            <td class="px-6 py-5 bg-black/20 text-xs opacity-60">@item.Servico</td>
                            <td class="px-6 py-5 bg-black/20 text-center font-mono text-[10px]">@item.DataHoraInicio.ToString("dd/MM/yy HH:mm")</td>
                            
                            <td class="px-6 py-5 bg-black/20 text-center">
                                <select id="select-@item.Id" onchange="atualizarStatus(@item.Id, this.value)" 
                                        class="status-select border-2 rounded-full px-4 py-1 text-[9px] font-black uppercase outline-none transition-all @statusClass bg-transparent">
                                    <option value="Pendente" class="opt-pendente" selected="@(item.Status == "Pendente")">Pendente</option>
                                    <option value="Atendido" class="opt-atendido" selected="@(item.Status == "Atendido")">Atendido</option>
                                    <option value="Cancelado" class="opt-cancelado" selected="@(item.Status == "Cancelado")">Cancelado</option>
                                </select>
                            </td>

                            <td class="px-6 py-5 bg-black/20 rounded-r-2xl text-right">
                                <button onclick="deletarAgendamento(@item.Id)" class="text-white/20 hover:text-red-500 transition-colors p-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div id="modalAgendamento" class="fixed inset-0 z-[9999] hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="fecharModal()"></div>
    <div class="relative min-h-screen flex items-center justify-center p-4">
        <div class="card-moderno w-full max-w-sm p-8 bg-[#0d0d0d] border border-white/10 shadow-2xl">
            <h3 class="text-lg font-black font-mono mb-6 uppercase italic text-indigo-500">Novo Registro</h3>
            <form id="formAgendamento" class="space-y-4">
                <div>
                    <label class="block text-[9px] font-black uppercase opacity-40 mb-1">Nome</label>
                    <input type="text" id="nomeCliente" required class="w-full bg-white/5 border-b border-white/20 p-2 outline-none focus:border-indigo-500 text-white font-bold text-sm">
                </div>
                <div>
                    <label class="block text-[9px] font-black uppercase opacity-40 mb-1">Serviço</label>
                    <input type="text" id="servico" required class="w-full bg-white/5 border-b border-white/20 p-2 outline-none focus:border-indigo-500 text-white font-bold text-sm">
                </div>
                <div>
                    <label class="block text-[9px] font-black uppercase opacity-40 mb-1">Data/Hora</label>
                    <input type="datetime-local" id="dataHora" required class="w-full bg-white/5 border-b border-white/20 p-2 outline-none focus:border-indigo-500 text-white font-bold text-sm">
                </div>
                <div class="flex justify-end gap-4 pt-4">
                    <button type="button" onclick="fecharModal()" class="text-[9px] font-black uppercase opacity-40 hover:opacity-100">Sair</button>
                    <button type="submit" id="btnSalvar" class="px-6 py-2 bg-indigo-600 text-white font-black text-[10px] rounded-md hover:bg-indigo-500">SALVAR</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function abrirModal() { document.getElementById('formAgendamento').reset(); document.getElementById('modalAgendamento').classList.remove('hidden'); }
    function fecharModal() { document.getElementById('modalAgendamento').classList.add('hidden'); }

    const form = document.getElementById('formAgendamento');
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        e.stopImmediatePropagation();
        const btn = document.getElementById('btnSalvar');
        if (btn.disabled) return;
        btn.disabled = true;
        btn.innerText = "...";

        const dados = {
            NomeCliente: document.getElementById('nomeCliente').value,
            Servico: document.getElementById('servico').value,
            DataHoraInicio: document.getElementById('dataHora').value
        };

        const res = await fetch('/Agendamentos/CriarAgendamento', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(dados)
        });
        const result = await res.json();
        if (result.success) location.reload();
        else { btn.disabled = false; btn.innerText = "ERRO"; }
    });

    async function atualizarStatus(id, novoStatus) {
        const select = document.getElementById(`select-${id}`);
        try {
            const res = await fetch(`/Agendamentos/MudarStatus?id=${id}&novoStatus=${novoStatus}`, { method: 'POST' });
            const result = await res.json();
            if (result.success) {
                select.classList.remove('status-pendente', 'status-atendido', 'status-cancelado');
                if (novoStatus === "Atendido") select.classList.add('status-atendido');
                else if (novoStatus === "Cancelado") select.classList.add('status-cancelado');
                else select.classList.add('status-pendente');
                
                const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1000, background: '#0d0d0d', color: '#fff' });
                Toast.fire({ icon: 'success', title: 'Status Atualizado' });
            }
        } catch (e) { console.error("Erro no fetch."); }
    }

    function deletarAgendamento(id) {
        Swal.fire({
            title: 'APAGAR?',
            text: "Essa ação é irreversível!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            background: '#0d0d0d', color: '#fff'
        }).then(async (result) => {
            if (result.isConfirmed) {
                const res = await fetch(`/Agendamentos/Excluir?id=${id}`, { method: 'DELETE' });
                const data = await res.json();
                if (data.success) location.reload();
            }
        });
    }
</script>