@model IEnumerable<ProjetoAgendamento.Models.Agendamento>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* CSS para esconder a barra de rolagem mantendo a funcionalidade de scroll em celulares */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    /* Efeito de brilho suave para os status */
    .status-glow-pendente { shadow-[0_0_10px_rgba(234,179,8,0.3)]; border-color: rgba(234,179,8,0.5); }
    .status-glow-atendido { shadow-[0_0_10px_rgba(34,197,94,0.3)]; border-color: rgba(34,197,94,0.5); }
    .status-glow-cancelado { shadow-[0_0_10px_rgba(239,68,68,0.3)]; border-color: rgba(239,68,68,0.5); }
</style>

<div class="card-moderno p-4 md:p-8 animate-in fade-in duration-500">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
        <div>
            <h2 class="text-2xl md:text-3xl font-black font-mono uppercase italic" style="color: var(--text-main)">Agendamentos</h2>
            <div class="h-1 w-20 bg-indigo-500 rounded-full mt-1"></div>
        </div>
        
        <button onclick="abrirModal()" class="w-full md:w-auto group relative px-8 py-3 font-bold rounded-2xl transition-all active:scale-95 shadow-xl overflow-hidden" 
                style="background: var(--accent); color: #000;">
            <span class="relative z-10">＋ NOVO_AGENDAMENTO</span>
        </button>
    </div>

    @* Estilo 2: Tabela sem barra visível e com espaçamento otimizado *@
    <div class="overflow-x-auto no-scrollbar">
        <table class="w-full text-left border-separate border-spacing-y-3 min-w-[600px] md:min-w-full">
            <thead>
                <tr class="text-[10px] uppercase tracking-widest opacity-50">
                    <th class="px-4 pb-2">Cliente</th>
                    <th class="px-4 pb-2">Serviço</th>
                    <th class="px-4 pb-2 text-center">Data/Hora</th>
                    <th class="px-4 pb-2 text-right">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any()) {
                    @foreach (var item in Model) {
                        var stClass = item.Status == "Atendido" ? "border-green-500/50 text-green-500 shadow-[0_0_8px_rgba(34,197,94,0.2)]" : 
                                     item.Status == "Cancelado" ? "border-red-500/50 text-red-500 shadow-[0_0_8px_rgba(239,68,68,0.2)]" : 
                                     "border-yellow-500/50 text-yellow-500 shadow-[0_0_8px_rgba(234,179,8,0.2)]";
                        
                        <tr class="group hover:scale-[1.01] transition-transform duration-200">
                            <td class="px-4 py-4 bg-black bg-opacity-20 rounded-l-2xl font-bold text-sm md:text-base">@item.NomeCliente</td>
                            <td class="px-4 py-4 bg-black bg-opacity-20 text-sm opacity-80">@item.Servico</td>
                            <td class="px-4 py-4 bg-black bg-opacity-20 text-center font-mono text-xs md:text-sm">@item.DataHoraInicio.ToString("dd/MM/yy HH:mm")</td>
                            <td class="px-4 py-4 bg-black bg-opacity-20 rounded-r-2xl text-right">
                                <span class="inline-block px-3 py-1 border-2 rounded-full text-[10px] font-black tracking-tighter @stClass">
                                    @item.Status.ToUpper()
                                </span>
                            </td>
                        </tr>
                    }
                } else {
                    <tr>
                        <td colspan="4" class="text-center py-20 opacity-30 italic font-mono uppercase tracking-widest">
                            Sistema Vazio // Aguardando Dados
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="modalAgendamento" class="fixed inset-0 z-[20000] hidden">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-xl"></div>
    <div class="relative min-h-screen flex items-center justify-center p-4">
        <div class="card-moderno w-full max-w-lg p-6 md:p-10 border-2 border-indigo-500/30 bg-[#0a0a0a] shadow-2xl">
            <h3 class="text-2xl font-black font-mono mb-8 uppercase italic" style="color: var(--text-main)">Criar Registro</h3>
            
            <form id="formAgendamento" class="space-y-6">
                <div>
                    <label class="block text-[10px] font-black uppercase opacity-50 ml-1 mb-1">Nome Cliente</label>
                    <input type="text" id="nomeCliente" required placeholder="Digite o nome..."
                           class="w-full bg-white/5 border-b-2 border-white/10 p-3 outline-none focus:border-indigo-500 transition-all font-bold text-white placeholder:opacity-20">
                </div>
                
                <div>
                    <label class="block text-[10px] font-black uppercase opacity-50 ml-1 mb-1">Serviço</label>
                    <input type="text" id="servico" required placeholder="Ex: Corte de Cabelo"
                           class="w-full bg-white/5 border-b-2 border-white/10 p-3 outline-none focus:border-indigo-500 transition-all font-bold text-white placeholder:opacity-20">
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase opacity-50 ml-1 mb-1">Data e Hora</label>
                    <input type="datetime-local" id="dataHora" required 
                           class="w-full bg-white/5 border-b-2 border-white/10 p-3 outline-none focus:border-indigo-500 transition-all font-bold text-white">
                </div>

                <div class="flex justify-end items-center space-x-6 mt-10">
                    <button type="button" onclick="fecharModal()" class="font-black text-[10px] opacity-40 hover:opacity-100 uppercase transition-all">Cancelar</button>
                    <button type="submit" class="px-10 py-3 rounded-xl font-black text-xs active:scale-95 transition-all shadow-lg shadow-indigo-500/20" 
                            style="background: var(--accent); color: #000;">
                        GRAVAR_DATABASE
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function abrirModal() { 
        document.getElementById('modalAgendamento').classList.remove('hidden'); 
    }
    function fecharModal() { 
        document.getElementById('modalAgendamento').classList.add('hidden'); 
    }

    document.getElementById('formAgendamento').addEventListener('submit', async function(e) {
        e.preventDefault();

        const dados = {
            NomeCliente: document.getElementById('nomeCliente').value,
            Servico: document.getElementById('servico').value,
            DataHoraInicio: document.getElementById('dataHora').value
        };

        try {
            const response = await fetch('/Agendamentos/CriarAgendamento', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });

            const result = await response.json();

            if (result.success) {
                Swal.fire({
                    title: 'REGISTRO SALVO',
                    text: result.message,
                    icon: 'success',
                    background: '#0a0a0a',
                    color: '#fff',
                    confirmButtonColor: '#6366f1',
                    confirmButtonText: 'CONFIRMAR'
                }).then(() => {
                    location.reload(); 
                });
            } else {
                Swal.fire({
                    title: 'ERRO NO SISTEMA',
                    text: result.message,
                    icon: 'error',
                    background: '#0a0a0a',
                    color: '#fff'
                });
            }
        } catch (error) {
            Swal.fire({
                title: 'CONEXÃO FALHOU',
                text: 'Não foi possível contatar o servidor local.',
                icon: 'warning',
                background: '#0a0a0a',
                color: '#fff'
            });
        }
    });
</script>